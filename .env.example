# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT secret — change to a long random string
JWT_SECRET=replace_with_long_random_secret_here

# SQLite database file path
DB_PATH=./database.sqlite

# Stripe keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Email (nodemailer) — for verification emails
# Using Gmail: enable "App Passwords" in your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=YardConnect <your@gmail.com>

# App URL (used in email links)
APP_URL=http://localhost:3000

# Admin panel secret code (type this in the login screen to open admin panel)
ADMIN_SECRET=changeme_pick_a_secret_code
