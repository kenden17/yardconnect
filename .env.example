# ============================================================
# Campus Hands — Environment Variables
# Copy this file to .env and fill in every value.
# Never commit .env to git.
# ============================================================

PORT=3000
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
# Generate both with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_long_random_string_min_48_chars
ADMIN_SECRET=replace_with_different_long_random_string

# ── Database ──────────────────────────────────────────────────
DB_PATH=./database.sqlite

# ── Stripe ────────────────────────────────────────────────────
# 1. Go to https://dashboard.stripe.com/test/apikeys
# 2. Copy "Secret key"  → STRIPE_SECRET_KEY   (starts with sk_test_)
# 3. Copy "Publishable key" → STRIPE_PUBLISHABLE_KEY (starts with pk_test_)
# 4. For webhooks: stripe listen --forward-to localhost:3000/api/payments/webhook
#    Copy the "whsec_..." key printed → STRIPE_WEBHOOK_SECRET
#
# Payments will return 503 until these are set.
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Email (SMTP) ──────────────────────────────────────────────
# Gmail: enable 2FA, then create an App Password at
#   https://myaccount.google.com/apppasswords
# Use the 16-char app password as SMTP_PASS (no spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Campus Hands <no-reply@campushands.app>

# ── App URL ───────────────────────────────────────────────────
# Used for Stripe redirect URLs after onboarding.
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000
